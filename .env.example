# Server Configuration
PORT=3000
NODE_ENV=production
CLIENT_URL=https://your-client-domain.com

# Firebase Admin Configuration (required)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id

# Security / Gateway
CORS_ORIGINS=https://your-app.com,https://admin.your-app.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
REQUIRE_IDEMPOTENCY_KEY=true
IDEMPOTENCY_TTL_MS=86400000
IDEMPOTENCY_LOCK_MS=60000

# VideoSDK Configuration
VIDEOSDK_API_KEY=your_videosdk_api_key
VIDEOSDK_SECRET_KEY=your_videosdk_secret_key

# VietQR Payment Configuration
VIETQR_ACCOUNT=your_bank_account_number
VIETQR_ACCOUNT_NAME=your_account_name
VIETQR_TEMPLATE=compact2
VIETQR_COIN_PACKAGES=[{"id":"coin_10","coins":10,"price":1000},{"id":"coin_50","coins":50,"price":2000},{"id":"coin_100","coins":100,"price":3000},{"id":"coin_500","coins":500,"price":5000}]
PRO_UPGRADE_PRICE=99000
WEBHOOK_SECRET=change_to_long_random_secret
CRON_SECRET=change_to_long_random_secret

# Optional integration flags
BANKING_API_ENABLED=false
BANKING_PROVIDER=vietqr

# AI Matchmaker (server-side only, never expose in Expo public env)
# Supports OpenAI-compatible chat completions providers such as OpenRouter.
OPENROUTER_API_KEY=your_openrouter_api_key
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=google/gemma-4-26b-a4b-it:free
AI_CHAT_MODEL=openai/gpt-oss-20b:free
AI_MODEL_FALLBACKS=openai/gpt-oss-20b:free,meta-llama/llama-3.3-70b-instruct:free,google/gemma-3-27b-it:free
AI_CHAT_ENABLED=true
AI_TIMEOUT_MS=12000
AI_MATCHMAKER_CANDIDATE_LIMIT=180
AI_HTTP_REFERER=https://saigondating-server.onrender.com
AI_APP_NAME=Saigon Dating
